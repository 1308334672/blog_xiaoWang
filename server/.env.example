# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=blog

# 服务端口（默认 3001）
PORT=3001

# 管理员密码（默认 admin123，请务必修改）
ADMIN_PASSWORD=change_me_please

# 允许的前端来源，多个用逗号分隔，* 表示全部放行
FRONTEND_ORIGIN=http://localhost:5173

# 受信任的生产环境 IP（支持任意端口）
# TRUSTED_HOSTS=http://47.103.138.24
